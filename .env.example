# Copy this file to .env for local development.
# Values in .env are loaded first by the CLI and override shell exports for this process.
# Use one KEY=value entry per line. Multiline values and shell expansion are not parsed.
# Inline comments start with whitespace followed by #; # inside token values is preserved.
# Leave optional values empty to skip that provider or feature.

# Prefer DeepSeek when configured.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Used when DEEPSEEK_API_KEY is empty.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional web search tool.
TAVILY_API_KEY=

# GitHub API token for private repos, higher rate limits, and PR comment publishing.
GITHUB_TOKEN=
GH_TOKEN=

# Agent/tool-loop tuning. Defaults to 40 when empty or invalid.
XENGINEER_MAX_TOOL_ROUNDS=40

# Optional live acceptance test controls.
XENGINEER_RUN_LIVE_AI_REVIEW_TEST=0
XENGINEER_LIVE_AI_REVIEW_PR_URL=
XENGINEER_LIVE_AI_REVIEW_REPORT_PATH=
