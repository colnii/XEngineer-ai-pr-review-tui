{
  "name": "xengineer-pr-review",
  "version": "0.1.0",
  "description": "One-command npm wrapper for the XEngineer AI PR reviewer",
  "bin": {
    "xengineer-pr-review": "bin/xengineer-pr-review.js"
  },
  "files": [
    "bin/",
    "src/xengineer_pr_review/**/*.py",
    "pyproject.toml",
    "README.md",
    "README.zh-CN.md",
    ".env.example"
  ],
  "scripts": {
    "release:check": "node scripts/run-python.js scripts/release_check.py",
    "prepublishOnly": "npm run release:check",
    "test": "node --test tests/npm-wrapper.test.js",
    "test:python": "node scripts/run-python.js -m pytest",
    "test:all": "npm test && npm run test:python"
  },
  "engines": {
    "node": ">=18"
  }
}
